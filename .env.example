# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Anthropic (Claude API) Configuration
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_API_KEY

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# Optional: For the sparkle.sh script (users can override with SPARKLE_API_URL env var)
SPARKLE_API_URL=http://localhost:3000

# Production URLs (uncomment and set when deploying)
# FRONTEND_URL=https://sparkle-cleaner.com
# API_BASE_URL=https://api.sparkle-cleaner.com
# SPARKLE_API_URL=https://api.sparkle-cleaner.com
