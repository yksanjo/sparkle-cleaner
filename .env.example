# Stripe Configuration
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Anthropic (Claude API) Configuration
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_API_KEY

# Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000

# Optional: For the sparkle.sh script (users can override with SPARKLE_API_URL env var)
SPARKLE_API_URL=http://localhost:3000

# Stripe Payment Link (create at dashboard.stripe.com → Payment Links)
# Paste your buy.stripe.com/... link here
SPARKLE_PAYMENT_LINK=https://buy.stripe.com/your_link_here

# Admin endpoint protection
ADMIN_SECRET=change_this_to_something_random

# Production: set these to your actual server URL when you deploy
# SPARKLE_API_URL=https://your-server-url.com
